<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_deep"
    android:fitsSystemWindows="true">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/bg_deep"
        app:titleTextColor="@color/text_primary"
        app:navigationIconTint="@color/text_primary"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingBottom="40dp">

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:indeterminateTint="@color/accent"
                android:visibility="gone"
                android:layout_marginBottom="16dp"/>

            <!-- Avatar + name hero -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card_accent"
                android:padding="28dp"
                android:gravity="center"
                android:layout_marginBottom="16dp">

                <ImageView
                    android:layout_width="68dp"
                    android:layout_height="68dp"
                    android:src="@drawable/ic_person_large"
                    android:scaleType="fitCenter"
                    android:background="@drawable/bg_avatar"
                    android:padding="14dp"
                    android:layout_marginBottom="14dp"
                    android:contentDescription="Profile avatar"/>

                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="20sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvEmail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:layout_marginTop="4dp"/>
            </LinearLayout>

            <!-- Info card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DETAILS"
                    android:textColor="@color/text_muted"
                    android:textSize="10sp"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="16dp"/>

                <!-- Phone row -->
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="14dp">
                    <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                        android:text="Phone" android:textColor="@color/text_muted" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvPhone" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:textColor="@color/text_primary" android:textSize="13sp"/>
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="@color/border" android:layout_marginBottom="14dp"/>

                <!-- Member since row -->
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:layout_width="90dp" android:layout_height="wrap_content"
                        android:text="Member since" android:textColor="@color/text_muted" android:textSize="13sp"/>
                    <TextView android:id="@+id/tvMemberSince" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:textColor="@color/text_primary" android:textSize="13sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Accounts section header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACCOUNTS"
                android:textColor="@color/text_muted"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:layout_marginBottom="10dp"
                android:layout_marginTop="4dp"/>

            <LinearLayout
                android:id="@+id/llProfileAccounts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
